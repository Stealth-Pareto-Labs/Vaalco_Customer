# =============================================================================
# VAALCO Fuel Intelligence — environment template
# Copy to `.env` for local dev. In the cloud, set these in each platform's
# secret manager (Render env, Modal secrets, Vercel env, GitHub Actions).
# NEVER commit a real `.env`.
# =============================================================================

# ---- LLM provider (reasoning layer; math always runs in Python) ----
LLM_PROVIDER=anthropic            # "anthropic" | "openai"
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Email (Resend preferred; SMTP fallback) ----
RESEND_API_KEY=
EMAIL_FROM=VAALCO Alerts <alerts@example.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ---- SMS (Twilio) — off by default ----
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Recipients (JSON array; optional) ----
# RECIPIENTS_JSON=[{"name":"Ops","email":"ops@example.com","phone":"+1...","sms_from_priority":"high"}]

# ---- Storage backend ----
STORAGE_BACKEND=file              # "file" (dev) | "supabase" (prod)
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
SUPABASE_BUCKET_RAW=raw-reports
SUPABASE_BUCKET_OUT=intelligence-runs

# ---- Auth (shared access code for the demo) ----
ACCESS_CODE=
SESSION_SECRET=

# ---- Deploy / CI credentials (used by CLIs, not the app) ----
GITHUB_TOKEN=
RENDER_API_KEY=

# ---- Domain / branding ----
MGO_PRICE_PER_M3=730
OPERATOR_NAME=VAALCO Energy
VESSEL_LABEL=Navigator Z (NZ-MCT)
FIELD_LABEL=ETAME Field, Offshore Gabon

# ---- Frontend (Next.js / Vercel) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
